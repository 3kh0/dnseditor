# GitHub App — user-to-server OAuth (required for opening PRs)
# Create at: https://github.com/settings/apps/new
GITHUB_APP_CLIENT_ID=
GITHUB_APP_CLIENT_SECRET=
# Public URL slug: https://github.com/apps/<slug>
GITHUB_APP_SLUG=

# Encrypts the login session cookie (any long random string).
# If unset, the app falls back to GITHUB_APP_CLIENT_SECRET.
SESSION_SECRET=

# Public URL of this app (used for OAuth callback). Required in production.
# Example: https://dnseditor.example.com
# Local dev can omit — the request host is used (http://localhost:3000).
NUXT_PUBLIC_APP_URL=

# Upstream DNS repo (defaults shown)
# DNS_GITHUB_OWNER=hackclub
# DNS_GITHUB_REPO=dns
# DNS_GITHUB_BRANCH=main
